# TeamSpeak 服务器配置
# 复制此文件为 .env 并填入你的实际配置

# NodeJS 服务器端口（示例 13344）
PORT=13344

# TeamSpeak 查询账号配置
TS_HOST=alecapu.top
TS_QUERY_PORT=10011
TS_USERNAME=api_user           # 最小权限专用 Query 帐号
TS_PASSWORD=lzrCWnsr           # 对应密码
TS_NICKNAME=ChannelBot         # 可自定义显示昵称

# TeamSpeak 虚拟服务器端口
TS_SERVER_PORT=9987

# 环境模式
NODE_ENV=production
